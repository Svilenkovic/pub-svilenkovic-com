<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Pub Šablon Beograd - Galerija fotografija. Pogledajte našu atmosferu, enterijer, hranu, piće i nezaboravne trenutke iz puba.">
    <meta name="keywords" content="Pub Šablon, galerija, fotografije, Beograd, pub, enterijer, hrana, događaji">
    <meta name="author" content="Pub Šablon Beograd">
    
    <title>Galerija | Pub Šablon Beograd</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="https://svilenkovic.com/favicon.ico">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- AOS Animation Library -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css">
    
    <!-- Styles -->
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="galerija.css">
</head>
<body>
    <!-- Header -->
    <header class="header header--solid" id="header">
        <div class="container">
            <nav class="nav">
                <a href="index" class="nav__logo">
                    <i class="fas fa-beer-mug-empty"></i>
                    <span>Pub Šablon</span>
                </a>

                <div class="nav__menu" id="nav-menu">
                    <ul class="nav__list">
                        <li class="nav__item">
                            <a href="index" class="nav__link">Početna</a>
                        </li>
                        <li class="nav__item">
                            <a href="meni" class="nav__link">Meni</a>
                        </li>
                        <li class="nav__item">
                            <a href="porudzbine" class="nav__link">Poruči Online</a>
                        </li>
                        <li class="nav__item">
                            <a href="o-nama" class="nav__link">O Nama</a>
                        </li>
                        <li class="nav__item">
                            <a href="galerija" class="nav__link active">Galerija</a>
                        </li>
                        <li class="nav__item">
                            <a href="kontakt" class="nav__link">Kontakt</a>
                        </li>
                    </ul>
                </div>

                <div class="nav__actions">
                    <a href="porudzbine" class="btn btn--primary btn--sm">
                        <i class="fas fa-shopping-bag"></i>
                        <span>Poruči</span>
                    </a>
                    <button class="nav__toggle" id="nav-toggle" aria-label="Toggle menu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                </div>
            </nav>
        </div>
    </header>

    <!-- Page Header -->
    <section class="page-header">
        <div class="page-header__overlay"></div>
        <div class="container">
            <div class="page-header__content" data-aos="fade-up">
                <h1 class="page-header__title">Galerija</h1>
                <p class="page-header__subtitle">Pogledajte atmosferu i trenutke iz Pub Šablona</p>
                <nav class="breadcrumb">
                    <a href="index">Početna</a>
                    <i class="fas fa-chevron-right"></i>
                    <span>Galerija</span>
                </nav>
            </div>
        </div>
    </section>

    <!-- Gallery Section -->
    <section class="section gallery-section">
        <div class="container">
            <!-- Gallery Filter -->
            <div class="gallery-filter" data-aos="fade-up">
                <button class="gallery-filter__btn active" data-filter="sve">
                    <i class="fas fa-th"></i>
                    Sve
                </button>
                <button class="gallery-filter__btn" data-filter="enterijer">
                    <i class="fas fa-couch"></i>
                    Enterijer
                </button>
                <button class="gallery-filter__btn" data-filter="hrana">
                    <i class="fas fa-utensils"></i>
                    Hrana
                </button>
                <button class="gallery-filter__btn" data-filter="pice">
                    <i class="fas fa-beer"></i>
                    Piće
                </button>
                <button class="gallery-filter__btn" data-filter="dogadjaji">
                    <i class="fas fa-calendar-alt"></i>
                    Događaji
                </button>
            </div>

            <!-- Gallery Grid -->
            <div class="gallery-grid" data-aos="fade-up" data-aos-delay="100">
                <!-- Enterijer -->
                <div class="gallery-item" data-category="enterijer">
                    <img src="https://images.unsplash.com/photo-1514933651103-005eec06c04b?w=600" alt="Pub Enterijer">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">Glavni Prostor</span>
                        <span class="gallery-item__category">Enterijer</span>
                    </div>
                </div>
                
                <div class="gallery-item" data-category="enterijer">
                    <img src="https://images.unsplash.com/photo-1525610553991-2bede1a236e2?w=600" alt="Bar">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">Bar</span>
                        <span class="gallery-item__category">Enterijer</span>
                    </div>
                </div>

                <div class="gallery-item" data-category="enterijer">
                    <img src="https://images.unsplash.com/photo-1572116469696-31de0f17cc34?w=600" alt="VIP Sekcija">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">VIP Sekcija</span>
                        <span class="gallery-item__category">Enterijer</span>
                    </div>
                </div>

                <!-- Hrana -->
                <div class="gallery-item" data-category="hrana">
                    <img src="https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=600" alt="Burger">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">Signature Burger</span>
                        <span class="gallery-item__category">Hrana</span>
                    </div>
                </div>

                <div class="gallery-item" data-category="hrana">
                    <img src="https://images.unsplash.com/photo-1513104890138-7c749659a591?w=600" alt="Pizza">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">Pizza</span>
                        <span class="gallery-item__category">Hrana</span>
                    </div>
                </div>

                <div class="gallery-item" data-category="hrana">
                    <img src="https://images.unsplash.com/photo-1544025162-d76694265947?w=600" alt="BBQ Rebarca">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">BBQ Rebarca</span>
                        <span class="gallery-item__category">Hrana</span>
                    </div>
                </div>

                <div class="gallery-item" data-category="hrana">
                    <img src="https://images.unsplash.com/photo-1546833998-877b37c2e5c6?w=600" alt="Wings">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">Buffalo Wings</span>
                        <span class="gallery-item__category">Hrana</span>
                    </div>
                </div>

                <!-- Piće -->
                <div class="gallery-item" data-category="pice">
                    <img src="https://images.unsplash.com/photo-1608270586620-248524c67de9?w=600" alt="Craft Pivo">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">Craft Pivo</span>
                        <span class="gallery-item__category">Piće</span>
                    </div>
                </div>

                <div class="gallery-item" data-category="pice">
                    <img src="https://images.unsplash.com/photo-1536935338788-846bb9981813?w=600" alt="Guinness">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">Guinness</span>
                        <span class="gallery-item__category">Piće</span>
                    </div>
                </div>

                <div class="gallery-item" data-category="pice">
                    <img src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=600" alt="Kokteli">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">Kokteli</span>
                        <span class="gallery-item__category">Piće</span>
                    </div>
                </div>

                <!-- Događaji -->
                <div class="gallery-item" data-category="dogadjaji">
                    <img src="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?w=600" alt="Živa Muzika">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">Živa Muzika</span>
                        <span class="gallery-item__category">Događaji</span>
                    </div>
                </div>

                <div class="gallery-item" data-category="dogadjaji">
                    <img src="https://images.unsplash.com/photo-1575444758702-4a6b9222336e?w=600" alt="Kviz Veče">
                    <div class="gallery-item__overlay">
                        <span class="gallery-item__title">Kviz Veče</span>
                        <span class="gallery-item__category">Događaji</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta section">
        <div class="cta__bg"></div>
        <div class="container">
            <div class="cta__content" data-aos="zoom-in">
