                <p class="cta__text">Cena sajta: 450€ + prva godina besplatno, posle 300€/godišnje.</p>
                <div class="cta__buttons">
                    <a href="https://svilenkovic.com/webshop" target="_blank" rel="noopener" class="btn btn--primary btn--large">
                        <i class="fas fa-shopping-cart"></i> Naruči Sada
                    </a>
                    <a href="tel:+381612248989" class="btn btn--outline btn--large">
                        <i class="fas fa-phone"></i> +381 61 224 8989
                    </a>
                </div>
            </div>
        </div>
    </section>

