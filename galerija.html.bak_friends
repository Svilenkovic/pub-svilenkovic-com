                            </li>
                            <li>
                                <i class="fas fa-phone"></i>
                                <a href="tel:+381612248989">+381 61 224 8989</a>
                            </li>
                            <li>
                                <i class="fas fa-envelope"></i>
                                <a href="mailto:dimitrije@svilenkovic.com">dimitrije@svilenkovic.com</a>
                            </li>
